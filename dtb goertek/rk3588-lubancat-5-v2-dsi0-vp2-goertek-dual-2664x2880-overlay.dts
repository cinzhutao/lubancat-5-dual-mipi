					0a 00 80 12 00 00 ab 30 80 0b 40 0a 68 05 a0 02 9a 02 9a 02 00 02 a1 00 20 85 ee 00 09 00 0f 00 16 00 0f 18 00 10 f0 07 10 20 00 06 0f 0f 33 0e 1c 2a 38 46 54 62 69 70 77 79 7b 7d 7e 02 02 22 00 2a 40 2a be 3a fc 3a fa 3a f8 3b 38 3b 78 3b b6 4b b6 4b f4 4b f4 6c 34 84 74 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00
				];

				panel-exit-sequence = [
					05 78 01 28
					05 00 01 10
				];

				compressed-data;
				slice-width = <666>;
				slice-height = <1440>;
				version-major = <1>;
				version-minor = <1>;

				disp0_timings0: display-timings {
					native-mode = <&dsi0_timing0>;
					dsi0_timing0: timing0 {
						clock-frequency = <856000000>;
						hactive = <2664>;
						vactive = <2880>;
						hback-porch = <200>;
						hfront-porch = <400>;
						hsync-len = <4>;
						vback-porch = <10>;
						vfront-porch = <30>;
						vsync-len = <1>;
						hsync-active = <0>;
						vsync-active = <0>;
						de-active = <0>;
						pixelclk-active = <0>;
					};
				};

				ports {
					#address-cells = <1>;
					#size-cells = <0>;
					port@0 {
						reg = <0>;
						panel_in_dsi0: endpoint {
							remote-endpoint = <&dsi0_out_panel>;
						};
					};
				};
			};

			ports {
				#address-cells = <1>;
				#size-cells = <0>;

				port@1 {
					reg = <1>;
					dsi0_out_panel: endpoint {
						remote-endpoint = <&panel_in_dsi0>;
					};
				};
			};
		};
	};

	fragment@7 {
		target = <&dsi1>;

		__overlay__ {
			status = "okay";
			#address-cells = <1>;
			#size-cells = <0>;

			dsi1_panel: panel@0 {
				status = "okay";
				compatible = "simple-panel-dsi";
				reg = <0>;
				backlight = <&backlight_dsi1>;
				power-supply = <&mipi_dsi1_power>;

				enable-delay-ms = <35>;
				prepare-delay-ms = <6>;
				reset-delay-ms = <2000>;
				init-delay-ms = <3000>;
				unprepare-delay-ms = <0>;
				disable-delay-ms = <20>;

				dsi,flags = <(MIPI_DSI_MODE_VIDEO |
					       MIPI_DSI_MODE_VIDEO_BURST |
					       MIPI_DSI_CLOCK_NON_CONTINUOUS |
					       MIPI_DSI_MODE_LPM)>;
				dsi,format = <MIPI_DSI_FMT_RGB888>;
				dsi,lanes = <8>;

				compressed-data;
				slice-width = <666>;
				slice-height = <1440>;
				version-major = <1>;
				version-minor = <1>;
			};
		};
	};

	fragment@8 {
		target = <&pwm0>;

		__overlay__ {
			pinctrl-0 = <&pwm0m0_pins>;
			status = "okay";
		};
	};

	fragment@9 {
		target = <&i2c1>;

		__overlay__ {
			status = "okay";
			#address-cells = <1>;
			#size-cells = <0>;
			pinctrl-names = "default";
			pinctrl-0 = <&i2c1m2_xfer>;

			gt911_dsi0: gt911@5d {
				status = "okay";
				compatible = "goodix,gt911";
				reg = <0x5d>;
				interrupt-parent = <&gpio1>;
				interrupts = <RK_PB3 IRQ_TYPE_LEVEL_LOW>;
				reset-gpios = <&gpio1 RK_PB4 GPIO_ACTIVE_LOW>;
				irq-gpios = <&gpio1 RK_PB3 GPIO_ACTIVE_HIGH>;
				touchscreen-inverted-x = <1>;
				touchscreen-inverted-y = <1>;
			};
		};
	};

	fragment@10 {
		target = <&backlight_dsi0>;

		__overlay__ {
			status = "okay";
		};
	};

	fragment@11 {
		target = <&pwm2>;

		__overlay__ {
			status = "okay";
		};
	};

	fragment@12 {
		target = <&backlight_dsi1>;

		__overlay__ {
			status = "okay";
		};
	};

	fragment@13 {
		target = <&pwm5>;

		__overlay__ {
			status = "okay";
		};
	};
};
