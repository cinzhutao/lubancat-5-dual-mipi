&pwm0 {
	pinctrl-0 = <&pwm0m0_pins>;
	status = "okay";
};

&dsi0 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	rockchip,dual-channel = <&dsi1>;
	rockchip,lane-rate = <1250000>;

	dsi0_panel: panel@0 {
		status = "okay";
		compatible = "simple-panel-dsi";
		reg = <0>;

		backlight = <&backlight_dsi0>;
		power-supply = <&mipi_dsi0_power>;
		reset-gpios = <&gpio1 RK_PA4 GPIO_ACTIVE_LOW>;

		enable-delay-ms = <35>;
		prepare-delay-ms = <6>;
		reset-delay-ms = <10>;
		init-delay-ms = <3000>;
		unprepare-delay-ms = <0>;
		disable-delay-ms = <20>;

		size,width = <74>;
		size,height = <133>;

		dsi,flags = <0xe03>;
		dsi,format = <0>;
		dsi,lanes = <8>;

		panel-init-sequence = [
			39 00 02 B0 00
			39 00 02 FF 00
			39 00 1C B1 00 18 18 00 18 18 00 18 18 00 18 18 00 18 18 00 18 18 00 18 18 00 18 18 00 18 18
			39 00 02 FF 01
			39 00 25 CC 8D E0 01 32 32 32 32 32 32 32 32 32 00 49 81 2C 00 40 00 08 0C 00 40 40 00 00 00 00
			00 00 00 02 00 FF FF FF
			39 00 02 FF 01
			39 00 02 EC 20
			39 00 02 FF 00
			39 00 02 03 01
			39 00 02 36 02
			39 00 03 51 FF FF
			39 00 02 65 90
			39 00 02 FF 01
			0A 00 80 12 00 00 AB 30 80 0B 40 0A 68 05 A0 02 9A 02 9A 02 00 02 A1 00 20 85 EE 00 09 00 0F 00
			16 00 0F 18 00 10 F0 07 10 20 00 06 0F 0F 33 0E 1C 2A 38 46 54 62 69 70 77 79 7B 7D 7E 02 02 22
			00 2A 40 2A BE 3A FC 3A FA 3A F8 3B 38 3B 78 3B B6 4B B6 4B F4 4B F4 6C 34 84 74 00 00 00 00 00
			00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00
			00 00 00
			39 00 02 FF 00
			39 00 02 B0 00
			39 00 01 29
			39 00 01 11
		];

		panel-exit-sequence = [
			05 78 01 28
			05 00 01 10
		];

		compressed-data;
		slice-width = <666>;
		slice-height = <1440>;
		version-major = <1>;
		version-minor = <1>;

		disp0_timings0: display-timings {
			native-mode = <&dsi0_timing0>;
			dsi0_timing0: timing0 {
				clock-frequency = <856000000>;
				hactive = <2664>;
				vactive = <2880>;
				hback-porch = <200>;
				hfront-porch = <400>;
				hsync-len = <4>;
				vback-porch = <10>;
				vfront-porch = <30>;
				vsync-len = <1>;
				hsync-active = <0>;
				vsync-active = <0>;
				de-active = <0>;
				pixelclk-active = <0>;
			};
		};

		ports {
			#address-cells = <1>;
			#size-cells = <0>;
			port@0 {
				reg = <0>;
				panel_in_dsi0: endpoint {
					remote-endpoint = <&dsi0_out_panel>;
				};
			};
		};
	};

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@1 {
			reg = <1>;
			dsi0_out_panel: endpoint {
				remote-endpoint = <&panel_in_dsi0>;
			};
		};
	};
};

&dsi1 {
	status = "okay";
};

&dsi0_in_vp2 {
	status = "okay";
};

&mipi_dcphy0 {
	status = "okay";
};

&mipi_dcphy1 {
	status = "okay";
};

&route_dsi0 {
	status = "okay";
	connect = <&vp2_out_dsi0>;
};

&i2c1 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;
	pinctrl-names = "default";
	pinctrl-0 = <&i2c1m2_xfer>;

	gt911_dsi0: gt911@5d {
		status = "okay";
		compatible = "goodix,gt911";
		reg = <0x5d>;
		interrupt-parent = <&gpio1>;
		interrupts = <RK_PB3 IRQ_TYPE_LEVEL_LOW>;
		reset-gpios = <&gpio1 RK_PB4 GPIO_ACTIVE_LOW>;
		irq-gpios = <&gpio1 RK_PB3 GPIO_ACTIVE_HIGH>;
		touchscreen-inverted-x = <1>;
		touchscreen-inverted-y = <1>;
	};
};
